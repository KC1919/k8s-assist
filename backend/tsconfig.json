{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "moduleResolution": "node",

    "ignoreDeprecations": "6.0",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}